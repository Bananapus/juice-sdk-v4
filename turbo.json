{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": ["dist/**"]
    },
    "test": {},
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "type-check": {}
  }
}
