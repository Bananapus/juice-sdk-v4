{
  "name": "@bananapus/nana-sdk-react",
  "version": "5.0.1",
  "description": "Wagmi hooks for Juicebox",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bananapus/juice-sdk-v4",
    "directory": "packages/react"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate-gql": "graphql-code-generator --config codegen.yml -r",
    "generate-gql:ci": "graphql-code-generator --config codegen.ci.yml",
    "generate-types": "echo '🔧 Generating types...' && tsc --emitDeclarationOnly",
    "prebuild": "rm -Rf dist",
    "build": "tsup && npm run generate-types",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit && tsc --project ./tsconfig.test.json"
  },
  "author": "tomquirk",
  "license": "ISC",
  "peerDependencies": {
    "@bananapus/nana-sdk-core": "*",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.3.1 || ^19.0.0",
    "viem": "^2.14.1",
    "wagmi": "^2.10.2"
  },
  "devDependencies": {
    "@bananapus/nana-sdk-core": "*",
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/client-preset": "^4.3.0",
    "@graphql-codegen/introspection": "^4.0.3",
    "@tanstack/react-query": "^5.101.4",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^3.2.7",
    "change-case": "^5.4.4",
    "react": "^19.2.8",
    "tsup": "^8.5.1",
    "viem": "^2.54.6",
    "vitest": "^3.2.6",
    "wagmi": "^2.17.5"
  },
  "files": [
    "dist/**/*"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "graphql-request": "^7.4.0"
  }
}
