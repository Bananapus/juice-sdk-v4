{
  "name": "@bananapus/nana-sdk-core",
  "version": "1.4.1",
  "type": "module",
  "scripts": {
    "generate": "wagmi generate",
    "postgenerate": "tsx ./scripts/addJBProjectDeploymentAddresses.ts",
    "prebuild": "rm -Rf dist/",
    "build": "npm run generate && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc --project ./tsconfig.json",
    "build:cjs": "tsc --project ./tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "dev": "tsc --project ./tsconfig.json --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit && tsc --project ./tsconfig.test.json"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./v6": {
      "types": "./dist/esm/v6/index.d.ts",
      "import": "./dist/esm/v6/index.js",
      "require": "./dist/cjs/v6/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "types": "./dist/esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "bs58": "^5.0.0",
    "fpnum": "^1.0.0"
  },
  "devDependencies": {
    "@bananapus/721-hook": "^1.0.0",
    "@bananapus/721-hook-v5": "^0.0.4",
    "@bananapus/721-hook-v6": "^1.1.0",
    "@bananapus/address-registry": "^1.0.0",
    "@bananapus/address-registry-v5": "0.0.2",
    "@bananapus/address-registry-v6": "^1.1.0",
    "@bananapus/buyback-hook": "^1.0.0",
    "@bananapus/buyback-hook-v5": "^0.0.2",
    "@bananapus/buyback-hook-v6": "^1.2.1",
    "@bananapus/core": "^1.0.5",
    "@bananapus/core-v5": "^0.0.6",
    "@bananapus/core-v6": "^1.1.1",
    "@bananapus/omnichain-deployers": "github:bananapus/nana-omnichain-deployers#42d39e1442cba9e916ad812112755629711fb759",
    "@bananapus/omnichain-deployers-v5": "^0.0.3",
    "@bananapus/omnichain-deployers-v6": "^1.1.0",
    "@bananapus/router-terminal-v6": "^1.2.1",
    "@bananapus/suckers": "^1.0.2",
    "@bananapus/suckers-v5": "0.0.2",
    "@bananapus/suckers-v6": "^1.1.2",
    "@bananapus/swap-terminal": "^1.0.1",
    "@bananapus/swap-terminal-v5": "^0.0.4",
    "@rev-net/core": "^1.0.1",
    "@rev-net/core-v5": "^0.0.3",
    "@rev-net/core-v6": "^1.1.0",
    "@wagmi/cli": "^2.10.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.20.5",
    "typescript": "^5.4.5",
    "viem": "^2.12.0",
    "vitest": "^3.2.6",
    "wagmi": "^2.10.2"
  }
}
